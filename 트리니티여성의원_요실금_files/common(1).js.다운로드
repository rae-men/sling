    if(parentId == null || parentId == undefined || parentId == ''){
        alert("답글 오류 입니다. 재 시도 부탁 드립니다.");
        return;
    } else {
        if(parentId <= 0){
            alert("답글 오류 입니다. 재 시도 부탁 드립니다.");
